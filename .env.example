# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write token (Editor) — only needed for the local content seed
# script (scripts/seed.mjs, git-ignored). Not read by the site itself.
SANITY_API_WRITE_TOKEN=your_sanity_write_token

# Spotify — "Off the clock" now-playing widget.
# Only the three below are read at runtime; the redirect URI and scopes
# (user-read-currently-playing) are only needed once when generating the
# refresh token.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# Letterboxd — "Off the clock" recently-watched widget
LETTERBOXD_USER=your_letterboxd_username
